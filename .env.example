# Copy to .env to override compose defaults. All vars have safe dev defaults.
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/facefinder
JWT_SECRET=dev-secret-change-me
JWT_EXPIRY_MINUTES=60
STORAGE_DIR=/app/storage

# face detection / matching — calibrate in plan 02
DET_SCORE_THRESHOLD=0.5
MATCH_BAND_STRONG=0.65
MATCH_BAND_POSSIBLE=0.45

# Seeded admin — auto-created on a fresh (empty) database so you can log in
# without first-run setup. Set a password (min 6 chars) to enable; leave empty
# to disable. Copy this file to .env (gitignored) and set real values there.
SEED_ADMIN_EMAIL=admin@facefinder.local
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin
